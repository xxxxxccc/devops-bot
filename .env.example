# DevOps Bot Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# Project Configuration
# ============================================

# Single-project mode: set a local path directly (backward compatible)
# TARGET_PROJECT_PATH=/path/to/your/project

# Multi-project mode: projects are added via chat ("add project <git URL>")
# and auto-cloned into REPOS_BASE_DIR. No TARGET_PROJECT_PATH needed.
# REPOS_BASE_DIR=~/.devops-bot/repos

# Workspace mode: register a workspace meta-repo ("add workspace <git URL>")
# The workspace repo must contain workspace.json listing all sub-projects.
# Sub-projects are cloned on demand when tasks target them.
# Optionally include CLAUDE.md in the workspace for org-wide AI context.

# Workspace directory for shared resources (skills, etc.)
# WORKSPACE_DIR=~/.devops-bot

# ============================================
# Webhook Server Configuration
# ============================================

# Server port
WEBHOOK_PORT=3200

# Authentication secret (required for API calls)
# WARNING: Change this from "dev-secret" in production!
WEBHOOK_SECRET=dev-secret

# ============================================
# AI Provider Configuration
# ============================================

# AI provider: anthropic | openai (default: anthropic)
# OpenAI mode also works with any OpenAI-compatible API (DeepSeek, Groq, Together, etc.)
# AI_PROVIDER=anthropic

# AI API key (required)
# For Anthropic: get from https://console.anthropic.com/
# For OpenAI:    get from https://platform.openai.com/api-keys
AI_API_KEY=your-api-key-here

# Custom base URL (optional, for OpenAI-compatible endpoints)
# Examples:
#   DeepSeek: https://api.deepseek.com/v1
#   Groq:     https://api.groq.com/openai/v1
#   Together: https://api.together.xyz/v1
# AI_BASE_URL=

# Task AI model (Layer 2 - intelligent, expensive)
# TASK_MODEL=claude-opus-4-5-20251101

# Dispatcher AI model (Layer 1 - fast, cheap)
# DISPATCHER_MODEL=claude-sonnet-4-5-20250929

# ============================================
# IM Platform Configuration
# ============================================

# IM platform: feishu | slack (default: feishu)
# IM_PLATFORM=feishu

# --- Feishu (Lark) ---
# WebSocket mode - no public IP needed
#
# Setup:
#   1. Create app: https://open.feishu.cn/app
#   2. Enable event: Events & Callbacks → Event Config → Use Long Connection
#   3. Add event: im.message.receive_v1
#   4. Add permissions: im:message, im:message:send_as_bot, im:resource, contact:user.base:readonly

FEISHU_APP_ID=
FEISHU_APP_SECRET=

# --- Slack ---
# Socket Mode - no public URL needed
#
# Setup:
#   1. Create app: https://api.slack.com/apps
#   2. Enable Socket Mode
#   3. Subscribe to events: message.channels, message.groups, message.im, app_mention
#   4. Add scopes: chat:write, files:read, users:read

# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ============================================
# Memory Configuration
# ============================================

# Extract memories every N messages in a conversation
# MEMORY_EXTRACT_THRESHOLD=5

# Model used for memory extraction (cheap model recommended)
# MEMORY_MODEL=claude-haiku-4-5-20251001

# ============================================
# Jira/Atlassian Integration (Optional)
# ============================================

# Jira configuration
# JIRA_URL=https://your-company.atlassian.net
# JIRA_USERNAME=your-email@company.com
# JIRA_API_TOKEN=your-jira-api-token

# Confluence configuration (shares token with Jira)
# CONFLUENCE_URL=https://your-company.atlassian.net/wiki
# CONFLUENCE_USERNAME=your-email@company.com
# CONFLUENCE_API_TOKEN=your-jira-api-token

# ============================================
# Figma Integration (Optional)
# ============================================

# Figma Personal Access Token
# Get it from: Figma → Settings → Personal access tokens → Generate new token
# FIGMA_API_KEY=figd_xxxxxxxxxxxx

# ============================================
# Embedding / Vector Search (Optional)
# ============================================

# Local embedding (recommended, no cost):
#   Run `devops-bot setup-embedding` to install node-llama-cpp
#   and pre-download the embeddinggemma-300M model (~300MB).
#   Or it auto-downloads on first search.

# OpenAI embedding fallback (if no local model available):
# OPENAI_API_KEY=sk-xxxxx

# ============================================
# Sandbox / Task Isolation (Optional)
# ============================================

# Base directory for git worktree sandboxes (default: /tmp/devops-bot-sandbox)
# SANDBOX_BASE_DIR=/tmp/devops-bot-sandbox

# Automatically create PR/MR after task completion (default: true)
# AUTO_CREATE_PR=true

# Create PRs as draft (default: true, recommended)
# PR_DRAFT=true

# Git platform authentication for PRs, Issues, and git push.
#
# --- GitHub App (recommended) ---
# Create a GitHub App: https://github.com/settings/apps/new
# Required permissions: Contents (read+write), Pull requests (read+write), Issues (read+write)
# After creating, install the App on your org/repos.
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY_PATH=/path/to/private-key.pem
# Or provide the key inline (base64-encoded):
# GITHUB_APP_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTi...
#
# --- GitHub PAT (fallback if no App configured) ---
# GITHUB_TOKEN=github_pat_xxxx
#
# --- GitLab (unchanged) ---
# GitLab (including self-hosted): User Settings → Access Tokens → api scope
# GITLAB_TOKEN=glpat-xxxx

# Max concurrent tasks (default: 3). Per-project serial, cross-project parallel.
# MAX_CONCURRENT_TASKS=3

# Approval poll interval in milliseconds (default: 1800000 = 30min).
# The poller checks pending Tier 2 issues for approval reactions.
# APPROVAL_POLL_INTERVAL_MS=1800000

# Label(s) used to discover external issues for automatic execution.
# Issues with this label AND an approval reaction will be picked up by the Issue AI.
# ISSUE_SCAN_LABELS=devops-bot

# AI model for the Issue AI (synthesizes tasks from issue discussions).
# Defaults to DISPATCHER_MODEL. Override for a different cost/quality trade-off.
# ISSUE_AI_MODEL=claude-sonnet-4-5-20250929

# ============================================
# PR Review Configuration (Optional)
# ============================================

# Enable automatic review of bot-created PRs after task completion.
# When enabled, also activates the auto-fix loop: if the review finds
# critical/warning issues, the bot automatically fixes them and pushes
# to the same PR branch, then re-reviews (max 2 rounds).
# ENABLE_SELF_REVIEW=false

# External PR review trigger mode:
#   polling — background poller scans registered projects for open PRs (default)
#   webhook — GitHub webhook on PR open/update (POST /webhook/github)
#   both    — poll + webhook
#   off     — no external triggers
# REVIEW_TRIGGER_MODE=polling

# PR review poll interval in milliseconds (default: 1800000 = 30min)
# Only used when REVIEW_TRIGGER_MODE=poll or both
# REVIEW_POLL_INTERVAL_MS=1800000

# Auto-scan all non-draft open PRs for review (default: true).
# Set to false to only review PRs with specific labels (see REVIEW_SCAN_LABELS).
# REVIEW_AUTO_SCAN=true

# Comma-separated labels that trigger PR review when REVIEW_AUTO_SCAN=false.
# Only PRs with at least one of these labels will be reviewed.
# REVIEW_SCAN_LABELS=needs-review

# AI model for PR review (defaults to TASK_MODEL)
# REVIEW_MODEL=claude-opus-4-5-20251101

# Inject review_pattern memories into task dispatcher context.
# Creates a feedback loop: recurring review findings improve future code generation.
# ENABLE_REVIEW_CROSS_INJECT=false

# Custom setup command after worktree creation (overrides auto-detection)
# Use for projects with non-standard dependency setup (iOS, Android, monorepos, etc.)
# Examples:
#   SANDBOX_SETUP_COMMAND="pod install"
#   SANDBOX_SETUP_COMMAND="./gradlew dependencies"
#   SANDBOX_SETUP_COMMAND="make deps"
# SANDBOX_SETUP_COMMAND=

# ============================================
# Attachment Storage (Optional)
# ============================================

# Upload IM attachments to external storage so they appear in Issue/PR markdown.
# Options: github-repo | gitlab-uploads | s3 | local | custom
# If not set, attachments remain local-only (images won't render in GitHub Issues).
# ATTACHMENT_STORAGE=github-repo

# --- github-repo (recommended) ---
# Push attachments to a dedicated GitHub repo. Uses GitHub App token for auth.
# Files stored at: {projectId}/{year-mm}/{hash}-{filename}
# ATTACHMENT_GITHUB_REPO=org/attachment-repo

# --- gitlab-uploads ---
# Uses GitLab Project Uploads API. Requires GITLAB_TOKEN (set above).
# ATTACHMENT_GITLAB_PROJECT=org/repo

# --- s3 ---
# AWS S3 bucket. Auth via IAM Role or AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
# ATTACHMENT_S3_BUCKET=my-bucket
# ATTACHMENT_S3_REGION=us-east-1
# ATTACHMENT_S3_PREFIX=attachments/
# ATTACHMENT_S3_CDN_URL=https://cdn.example.com

# --- local ---
# Serve files from data/attachments/ via the bot's HTTP server.
# Requires the bot to be reachable from where Issues are viewed.
# ATTACHMENT_BASE_URL=https://my-bot.example.com:3200

# --- custom ---
# POST multipart/form-data to a custom endpoint; expects JSON { url: "..." } response.
# ATTACHMENT_CUSTOM_UPLOAD_URL=https://my-upload-api.com/upload
# ATTACHMENT_CUSTOM_HEADERS=Authorization: Bearer xxx

# ============================================
# Optional
# ============================================

# Log level (debug/info/warn/error)
LOG_LEVEL=info
